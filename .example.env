# ─────────────────────────────────────────────────────────────────────────────
# MUSILA BACKEND — Variables de Entorno
# Copia este archivo a .env.local, .env.development o .env.production
# según el entorno que vayas a configurar.
# ─────────────────────────────────────────────────────────────────────────────

# Entorno de ejecución
# Valores válidos: local | development | production
NODE_ENV=local

# Puerto del servidor HTTP (opcional, default: 3001)
PORT=3001

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────────────────────────────────────

# Conexión por parámetros individuales — solo para NODE_ENV=local
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=

# Conexión por URL completa — solo para NODE_ENV=development (Supabase / Postgres remoto)
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=

# Conexión por URL completa — solo para NODE_ENV=production
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DB_URL=

# ─────────────────────────────────────────────────────────────────────────────
# AUTENTICACIÓN JWT
# ─────────────────────────────────────────────────────────────────────────────

# Cadena secreta para firmar los tokens JWT (usa un valor largo y aleatorio)
JWT_SECRET=

# Tiempo de expiración del token (default en código: 48h)
# Ejemplos: 3600s | 1h | 24h | 7d
JWT_EXPIRATION=48h

# ─────────────────────────────────────────────────────────────────────────────
# ALMACENAMIENTO DE ARCHIVOS (compatible con S3 — AWS S3, Cloudflare R2, etc.)
# ─────────────────────────────────────────────────────────────────────────────

STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_KEY=
STORAGE_REGION=
# Endpoint del servicio S3 (dejar vacío para AWS nativo)
# Ejemplo Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=
STORAGE_BUCKET=

# ─────────────────────────────────────────────────────────────────────────────
# URLS DE LA APLICACIÓN WEB (frontend)
# Usadas para CORS, WebSocket y generación de URLs de invitación
# ─────────────────────────────────────────────────────────────────────────────

# URL del frontend en entorno local (ej: http://localhost:3000)
WEB_APP_LOCAL=http://localhost:3000

# URL del frontend en entorno de desarrollo/staging
WEB_APP_DEVELOPMENT=

# URL del frontend en entorno de producción
WEB_APP_PRODUCTION=

# ─────────────────────────────────────────────────────────────────────────────
# SERVICIO DE EMAIL (Resend — https://resend.com)
# ─────────────────────────────────────────────────────────────────────────────

# Ruta al ejecutable de Chrome/Chromium para generación de PDF con Puppeteer
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# Linux:   /usr/bin/google-chrome  o  /usr/bin/chromium-browser
CHROME_PATH=

# API Key de Resend (comienza con "re_")
RESEND_API_KEY=

# Dirección de correo remitente verificada en Resend
# Formato: Nombre <correo@dominio.com>
EMAIL_FROM=

# Dirección de reply-to para los correos enviados
EMAIL_REPLY_TO=

# ─────────────────────────────────────────────────────────────────────────────
# WOMPI (https://docs.wompi.co) — pasarela de pagos (COP)
# Llaves disponibles en el panel: comercios.wompi.co → Desarrolladores.
# SANDBOX: las llaves comienzan con "pub_test_" / "prv_test_".
# PRODUCCIÓN: las llaves comienzan con "pub_prod_" / "prv_prod_".
# ─────────────────────────────────────────────────────────────────────────────

# Llave pública: se usa en el frontend (Widget) y para tokenizar tarjetas.
WOMPI_PUBLIC_KEY=

# Llave privada: SOLO backend. Crea payment_sources y transactions. Nunca exponer al cliente.
WOMPI_PRIVATE_KEY=

# Secreto de eventos: valida el checksum de los webhooks (sección "Eventos" del panel).
WOMPI_EVENTS_SECRET=

# Secreto de integridad: firma la transacción del Widget (sección "Integridad" del panel).
WOMPI_INTEGRITY_SECRET=

# URL base de la API de Wompi.
# Sandbox:    https://sandbox.wompi.co/v1
# Producción: https://production.wompi.co/v1
WOMPI_API_URL=https://sandbox.wompi.co/v1

# URL base de este backend — usada para construir la URL del webhook.
# Ejemplo producción: https://api.musila.co
# Ejemplo local (con ngrok): https://abc123.ngrok.io
API_ENDPOINT=http://localhost:3001